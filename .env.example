# App environment
APP_ENV=development

# Logging
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=%(asctime)s | %(levelname)s | %(name)s | %(message)s

# API
API_HOST=0.0.0.0
API_SERVER_PORT=8000
API_PIPELINE_PORT=8010
API_MAX_CONCURRENT_ENVS=1

# Inference
INFERENCE_BASE_URL=http://localhost:8000
INFERENCE_TIMEOUT_SECONDS=10
INFERENCE_RETRY_ATTEMPTS=3
INFERENCE_RETRY_BACKOFF_SECONDS=0.5

# Cache
CACHE_ENABLED=true
CACHE_INFERENCE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=1024

# Benchmark
BENCHMARK_DEFAULT_RUNS=1
BENCHMARK_DEFAULT_CONCURRENCY=4

# Environment behavior
ENV_DEBUG=false
